# utils module for LAMA - handy helper functions

fn clamp(val, lo, hi):
    if val < lo:
        return lo
    elif val > hi:
        return hi
    else:
        return val

fn max(a, b):
    if a > b:
        return a
    return b

fn min(a, b):
    if a < b:
        return a
    return b

fn abs_val(n):
    if n < 0:
        return n * -1
    return n
